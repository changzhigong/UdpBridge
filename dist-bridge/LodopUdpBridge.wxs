<?xml version="1.0" encoding="UTF-8"?>
<!--
  LodopUdpBridge.wxs - WiX 3 installer config
  Supports: Install, Uninstall, Repair
  Install dir: Program Files\LodopUdpBridge
  Start menu: LodopUdpBridge (Start + Uninstall)
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="LodopUdpBridge"
    Language="1033"
    Version="1.0.0"
    Manufacturer="FY App"
    UpgradeCode="8A9B8C7D-6E5F-4A3B-2C1D-0E1F2A3B4C5D">

    <!-- Package properties -->
    <Package
      Id="*"
      Keywords="Lodop,UDP,Print,Bridge"
      Description="LodopUdpBridge LAN Print Gateway"
      Comments="Java backend + system tray"
      Manufacturer="FY App"
      InstallerVersion="300"
      Languages="1033"
      Compressed="yes"
      InstallScope="perMachine"
      Platform="x64" />

    <!-- Media -->
    <Media Id="1" Cabinet="LodopUdpBridge.cab" EmbedCab="yes" />

    <!-- Upgrade strategy -->
    <Upgrade Id="8A9B8C7D-6E5F-4A3B-2C1D-0E1F2A3B4C5D">
      <UpgradeVersion
        Minimum="0.0.0.0" IncludeMinimum="yes"
        Maximum="99.0.0.0" IncludeMaximum="no"
        Property="UPGRADEFOUND" />
    </Upgrade>

    <!-- Install directory structure -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder" Name="PFiles">
        <Directory Id="INSTALLDIR" Name="LodopUdpBridge">
          <!-- Main program files -->
          <Component Id="MainFiles" Guid="A1B2C3D4-E5F6-7890-1234-567890ABCDEF">
            <File Id="LodopUdpBridgeJar" Name="LodopUdpBridge.jar" Source="LodopUdpBridge.jar" KeyPath="yes" />
            <File Id="RunBat" Name="run.bat" Source="run.bat" />
            <!-- logs directory: writeable by users -->
            <CreateFolder>
              <Permission User="Users" GenericAll="yes" />
            </CreateFolder>
          </Component>
        </Directory>
      </Directory>

      <!-- Start menu -->
      <Directory Id="ProgramMenuFolder" Name="Programs">
        <Directory Id="AppProgramMenuDir" Name="LodopUdpBridge">
          <Component Id="ProgramMenuDir" Guid="B2C3D4E5-F6A7-8901-2345-678901BCDEF0">
            <RemoveFolder Id="RemoveAppProgramMenuDir" Directory="AppProgramMenuDir" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\LodopUdpBridge" Name="installed" Type="integer" Value="1" KeyPath="yes" />
            <!-- Start shortcut -->
            <Shortcut
              Id="StartMenuShortcut"
              Name="Start LodopUdpBridge"
              Description="Start LodopUdpBridge print gateway"
              Target="[#RunBat]"
              WorkingDirectory="INSTALLDIR" />
            <!-- Uninstall shortcut -->
            <Shortcut
              Id="UninstallShortcut"
              Name="Uninstall LodopUdpBridge"
              Description="Uninstall LodopUdpBridge"
              Target="[System64Folder]msiexec.exe"
              Arguments="/x [ProductCode]" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <!-- Features -->
    <Feature Id="Complete" Title="LodopUdpBridge" Level="1">
      <ComponentRef Id="MainFiles" />
      <ComponentRef Id="ProgramMenuDir" />
    </Feature>

    <!-- Install execute sequence -->
    <InstallExecuteSequence>
      <RemoveExistingProducts After="InstallInitialize" />
    </InstallExecuteSequence>

    <!-- Install UI -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
    <UIRef Id="WixUI_InstallDir" />

    <!-- Add/Remove Programs info -->
    <Property Id="ARPCONTACT">FY App</Property>
    <Property Id="ARPHELPLINK">https://github.com/changzhigong/fycrg-app</Property>
    <Property Id="ARPURLINFOABOUT">https://github.com/changzhigong/fycrg-app</Property>

  </Product>
</Wix>
